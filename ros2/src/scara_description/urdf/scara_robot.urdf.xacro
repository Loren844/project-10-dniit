<?xml version="1.0" encoding="UTF-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="scara_robot">

  <xacro:property name="a2"    value="0.4"/>
  <xacro:property name="a3"    value="0.3"/>
  <xacro:property name="d3"    value="0.1"/>
  <xacro:property name="d4"    value="0.15"/>
  <xacro:property name="col_h" value="0.6"/>
  <xacro:property name="col_r" value="0.05"/>
  <xacro:property name="d2max" value="0.4"/>

  <material name="dark_grey"><color rgba="0.20 0.20 0.22 1.0"/></material>
  <material name="steel">    <color rgba="0.70 0.70 0.72 1.0"/></material>
  <material name="blue">     <color rgba="0.08 0.38 0.82 1.0"/></material>
  <material name="orange">   <color rgba="0.96 0.44 0.00 1.0"/></material>

  <xacro:arg name="controllers_yaml" default=""/>

  <ros2_control name="scara_control" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="joint_1z">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">${d2max}</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.40</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_1theta">
      <command_interface name="position">
        <param name="min">-2.3562</param>
        <param name="max">2.3562</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint3">
      <command_interface name="position">
        <param name="min">-1.5708</param>
        <param name="max">1.5708</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.3</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint4">
      <command_interface name="position">
        <param name="min">-3.1416</param>
        <param name="max">3.1416</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <link name="world"/>

  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${col_h/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${col_r}" length="${col_h}"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${col_h/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${col_r}" length="${col_h}"/></geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 ${col_h/2}"/>
      <inertia ixx="0.15" ixy="0" ixz="0"
               iyy="0.15" iyz="0" izz="0.006"/>
    </inertial>
  </link>

  <link name="slide_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <link name="arm1_link">
    <visual>
      <origin xyz="${a2/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${a2} 0.050 0.040"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="${a2/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${a2} 0.050 0.040"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="${a2/2} 0 0"/>
      <inertia ixx="0.00065" ixy="0" ixz="0"
               iyy="0.01338" iyz="0" izz="0.01338"/>
    </inertial>
  </link>

  <link name="arm2_link">
    <visual>
      <origin xyz="0 0 ${d3/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="0.022" length="${d3}"/></geometry>
      <material name="steel"/>
    </visual>
    <visual>
      <origin xyz="${a3/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${a3} 0.045 0.035"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="${a3/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${a3} 0.045 0.035"/></geometry>
    </collision>
    <inertial>
      <mass value="0.7"/>
      <origin xyz="${a3/2} 0 0"/>
      <inertia ixx="0.00044" ixy="0" ixz="0"
               iyy="0.00536" iyz="0" izz="0.00536"/>
    </inertial>
  </link>

  <link name="tool_link">
    <visual>
      <origin xyz="0 0 ${-d4/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="0.020" length="${d4}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${-d4/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="0.020" length="${d4}"/></geometry>
    </collision>
    <inertial>
      <mass value="0.10"/>
      <origin xyz="0 0 ${-d4/2}"/>
      <inertia ixx="0.00009" ixy="0" ixz="0"
               iyy="0.00009" iyz="0" izz="0.00002"/>
    </inertial>
  </link>

  <joint name="joint_1z" type="prismatic">
    <parent link="base_link"/>
    <child  link="slide_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit  lower="0.0" upper="${d2max}" effort="50.0" velocity="0.5"/>
    <dynamics damping="5.0" friction="2.0"/>
  </joint>

  <joint name="joint_1theta" type="revolute">
    <parent link="slide_link"/>
    <child  link="arm1_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit  lower="-2.3562" upper="2.3562" effort="20.0" velocity="3.14"/>
    <dynamics damping="0.10" friction="0.05"/>
  </joint>

  <joint name="joint3" type="revolute">
    <parent link="arm1_link"/>
    <child  link="arm2_link"/>
    <origin xyz="${a2} 0 ${-d3}" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit  lower="-1.5708" upper="1.5708" effort="15.0" velocity="3.14"/>
    <dynamics damping="0.10" friction="0.05"/>
  </joint>

  <joint name="joint4" type="revolute">
    <parent link="arm2_link"/>
    <child  link="tool_link"/>
    <origin xyz="${a3} 0 0" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit  lower="-3.1416" upper="3.1416" effort="5.0" velocity="6.28"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controllers_yaml)</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="base_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="arm1_link"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="arm2_link"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="tool_link"><material>Gazebo/Orange</material></gazebo>

<link name="camera_link">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="world"/>
    <child link="camera_link"/>
    <origin xyz="0.55 0.0 0.8" rpy="0 1.5708 0"/>
  </joint>

  <gazebo>
    <plugin filename="libignition-gazebo-sensors-system.so" name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="overhead_camera" type="camera">
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>RGB_INT8</format>
        </image>
        <clip>
          <near>0.01</near>
          <far>10.0</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>/camera/image_raw</topic>
    </sensor>
  </gazebo>
</robot>
